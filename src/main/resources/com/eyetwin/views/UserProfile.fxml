<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.Circle?>

<!--
    UserProfile.fxml
    Mirrors: user/profile.html.twig
    Controller: com.eyetwin.controller.UserProfileController
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.UserProfileController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #06050f;"
            prefWidth="1280" prefHeight="800">

    <!-- ══════════════════════════════════════════════════
         NAVBAR — logo + profile dropdown only
    ══════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: rgba(8,8,16,0.97);
                     -fx-border-color: rgba(232,55,42,0.15);
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24; -fx-pref-height: 64;">

            <!-- Logo -->
            <ImageView fitHeight="38" preserveRatio="true" pickOnBounds="true"
                       onMouseClicked="#goHome" style="-fx-cursor: hand;">
                <image><Image url="@../assets/img/eyetwin-logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Right zone: coins + profile dropdown -->
            <HBox fx:id="loggedInZone" alignment="CENTER" spacing="8" visible="true" managed="true">
                <HBox fx:id="coinsBadge" alignment="CENTER" spacing="6" onMouseClicked="#goToCoins"
                      style="-fx-background-color: linear-gradient(90deg,#f6d860,#f6ad55);
                             -fx-background-radius: 20; -fx-padding: 5 13; -fx-cursor: hand;">
                    <Label text="🪙" style="-fx-font-size: 11;"/>
                    <Label fx:id="coinsNavLabel" text="0"
                           style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #1a1a2e;"/>
                </HBox>

                <MenuButton fx:id="navProfileMenu"
                            style="-fx-background-color: rgba(255,255,255,0.03);
                                   -fx-border-color: rgba(232,55,42,0.18);
                                   -fx-border-radius: 50; -fx-background-radius: 50;
                                   -fx-padding: 4 12 4 4;
                                   -fx-mark-color: rgba(255,255,255,0.3); -fx-cursor: hand;">
                    <graphic>
                        <HBox alignment="CENTER" spacing="7">
                            <StackPane style="-fx-background-color: linear-gradient(135deg,#b02b20,#ff4d3d);
                                              -fx-background-radius: 50;
                                              -fx-min-width: 28; -fx-min-height: 28;
                                              -fx-max-width: 28; -fx-max-height: 28;">
                                <Label fx:id="navAvatarInitial" text="A"
                                       style="-fx-text-fill: white; -fx-font-weight:900; -fx-font-size:12;"/>
                            </StackPane>
                            <Label fx:id="navUsername" text="PLAYER"
                                   style="-fx-text-fill: white; -fx-font-weight:bold; -fx-font-size:10;"/>
                            <Label text="●" style="-fx-text-fill: #00e676; -fx-font-size: 7;"/>
                        </HBox>
                    </graphic>
                    <items>
                        <MenuItem fx:id="profileHeaderItem" text="" disable="true"
                                  style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.35);"/>
                        <MenuItem fx:id="profileStatsItem"  text="" disable="true"
                                  style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10;"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="👤  My Profile"       onAction="#goToProfile"   style="-fx-font-size:11;"/>
                        <MenuItem text="✏  Edit Profile"      onAction="#goToEditProfile" style="-fx-font-size:11;"/>
                        <MenuItem text="🛡  Two-Factor Auth"  onAction="#goTo2FA"        style="-fx-font-size:11;"/>
                        <MenuItem text="🎧  Support"          onAction="#goToSupport"    style="-fx-font-size:11;"/>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="profileAdminItem" text="⚙  Administration" visible="false"
                                  onAction="#goToAdmin"
                                  style="-fx-font-size:11; -fx-text-fill:#f6d860;"/>
                        <SeparatorMenuItem fx:id="profileAdminSep" visible="false"/>
                        <MenuItem text="🚪  Logout" onAction="#handleLogout"
                                  style="-fx-font-size:11; -fx-text-fill:#ff4d3d;"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox style="-fx-background-color: #06050f;">

                <!-- ── PAGE HERO ── -->
                <VBox style="-fx-padding: 36 80 28 80;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-border-width: 0 0 1 0;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="My Profile"
                               style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                      -fx-font-size: 28; -fx-font-weight: bold;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 4 0 0 0;">
                        <Label text="Home" onMouseClicked="#goHome"
                               style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 12; -fx-cursor: hand;"/>
                        <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 12;"/>
                        <Label text="Profile"
                               style="-fx-text-fill: #e8372a; -fx-font-size: 12;"/>
                    </HBox>
                </VBox>

                <!-- ── COACH CONGRATULATIONS BANNER ── -->
                <VBox fx:id="coachCongratsBanner" visible="false" managed="false"
                      style="-fx-padding: 0 80 0 80;">
                    <HBox spacing="20" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(102,126,234,0.12);
                                 -fx-border-color: rgba(102,126,234,0.35);
                                 -fx-border-width: 1 1 1 4;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 22 28;">
                        <Label text="🎓" style="-fx-font-size: 36;"/>
                        <VBox spacing="4">
                            <Label text="🎉 Congratulations! You are now a certified Coach"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 16; -fx-font-weight: bold;"/>
                            <Label text="You can now create live streams and help other players improve their skills."
                                   style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── MAIN CONTENT: LEFT + RIGHT ── -->
                <HBox spacing="24" style="-fx-padding: 28 80 48 80;" alignment="TOP_LEFT">

                    <!-- ════ LEFT COLUMN ════ -->
                    <VBox spacing="16" style="-fx-min-width: 300; -fx-pref-width: 300; -fx-max-width: 300;">

                        <!-- Profile Card -->
                        <VBox style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(232,55,42,0.2); -fx-border-width: 1;
                                     -fx-border-radius: 12; -fx-background-radius: 12;">

                            <!-- Avatar section -->
                            <VBox alignment="CENTER" spacing="0"
                                  style="-fx-padding: 28 20 18 20;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 0 0 1 0;">
                                <StackPane>
                                    <ImageView fx:id="profileImageView"
                                               fitWidth="96" fitHeight="96"
                                               preserveRatio="false" smooth="true"
                                               visible="false" managed="false">
                                        <clip>
                                            <Circle centerX="48" centerY="48" radius="48"/>
                                        </clip>
                                    </ImageView>
                                    <StackPane fx:id="avatarPlaceholder"
                                               style="-fx-background-color: linear-gradient(135deg,#b02b20,#ff4d3d);
                                                      -fx-background-radius: 50;
                                                      -fx-min-width: 96; -fx-min-height: 96;
                                                      -fx-max-width: 96; -fx-max-height: 96;">
                                        <Label fx:id="avatarInitial" text="A"
                                               style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                                      -fx-font-size: 38; -fx-font-weight: bold;"/>
                                    </StackPane>
                                </StackPane>

                                <!-- AI Avatar buttons -->
                                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 12 0 0 0;">
                                    <Button text="✦  AI Avatar" onAction="#openAiAvatarDialog"
                                            style="-fx-background-color: rgba(102,126,234,0.85);
                                                   -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;
                                                   -fx-background-radius: 20; -fx-padding: 6 14;
                                                   -fx-border-width: 0; -fx-cursor: hand;"/>
                                    <Button text="🤖  Cartoon" onAction="#openCycleGANDialog"
                                            style="-fx-background-color: rgba(236,72,153,0.85);
                                                   -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;
                                                   -fx-background-radius: 20; -fx-padding: 6 14;
                                                   -fx-border-width: 0; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>

                            <!-- User info -->
                            <VBox alignment="CENTER" spacing="6"
                                  style="-fx-padding: 18 20 16 20;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 0 0 1 0;">
                                <Label fx:id="usernameLabel" text="USERNAME"
                                       style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                              -fx-font-size: 18; -fx-font-weight: bold;"/>
                                <Label fx:id="emailLabel" text="user@email.com"
                                       style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 12;"/>

                                <!-- Status badges -->
                                <HBox alignment="CENTER" spacing="7" style="-fx-padding: 6 0 0 0;">
                                    <Label fx:id="statusActiveBadge" text="● Active"
                                           style="-fx-background-color: rgba(0,230,118,0.1);
                                                  -fx-border-color: rgba(0,230,118,0.3); -fx-border-width: 1;
                                                  -fx-border-radius: 20; -fx-background-radius: 20;
                                                  -fx-text-fill: #00e676; -fx-font-size: 10;
                                                  -fx-font-weight: bold; -fx-padding: 4 12;"/>
                                    <Label fx:id="coachBadge" text="🎓 Coach" visible="false" managed="false"
                                           style="-fx-background-color: rgba(102,126,234,0.12);
                                                  -fx-border-color: rgba(102,126,234,0.3); -fx-border-width: 1;
                                                  -fx-border-radius: 20; -fx-background-radius: 20;
                                                  -fx-text-fill: #667eea; -fx-font-size: 10;
                                                  -fx-font-weight: bold; -fx-padding: 4 12;"/>
                                    <Label fx:id="adminBadge" text="🛡 Admin" visible="false" managed="false"
                                           style="-fx-background-color: rgba(232,55,42,0.1);
                                                  -fx-border-color: rgba(232,55,42,0.3); -fx-border-width: 1;
                                                  -fx-border-radius: 20; -fx-background-radius: 20;
                                                  -fx-text-fill: #ff5545; -fx-font-size: 10;
                                                  -fx-font-weight: bold; -fx-padding: 4 12;"/>
                                </HBox>
                            </VBox>

                            <!-- Actions -->
                            <VBox spacing="9" style="-fx-padding: 16 20 20 20;">
                                <Button fx:id="applyCoachBtn" text="🎓  Apply to be a Coach"
                                        maxWidth="1.7976931348623157E308"
                                        onAction="#goToApplyCoach"
                                        visible="true" managed="true"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: rgba(102,126,234,0.45); -fx-border-width: 1;
                                               -fx-border-radius: 8; -fx-background-radius: 8;
                                               -fx-text-fill: #667eea; -fx-font-size: 12;
                                               -fx-font-weight: bold; -fx-padding: 11 0; -fx-cursor: hand;"/>
                                <Button text="✏  Edit Profile"
                                        maxWidth="1.7976931348623157E208"
                                        onAction="#goToEditProfile"
                                        style="-fx-background-color: #e8372a; -fx-border-width: 0;
                                               -fx-text-fill: white; -fx-font-size: 12;
                                               -fx-font-weight: bold; -fx-background-radius: 8;
                                               -fx-padding: 11 0; -fx-cursor: hand;"/>
                            </VBox>
                        </VBox>

                        <!-- About Me Card -->
                        <VBox fx:id="bioCard" visible="false" managed="false"
                              style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(232,55,42,0.18); -fx-border-width: 1;
                                     -fx-border-radius: 12; -fx-background-radius: 12;
                                     -fx-padding: 20 22;">
                            <Label text="👤  ABOUT ME"
                                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10;
                                          -fx-font-weight: bold; -fx-padding: 0 0 10 0;"/>
                            <Label fx:id="bioLabel" text=""
                                   wrapText="true"
                                   style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12;
                                          -fx-line-spacing: 3;"/>
                        </VBox>

                        <!-- Coach Application Status -->
                        <VBox fx:id="coachApplicationCard" visible="false" managed="false"
                              style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(232,55,42,0.18); -fx-border-width: 1;
                                     -fx-border-radius: 12; -fx-background-radius: 12;
                                     -fx-padding: 20 22;">
                            <Label text="🎓  COACH APPLICATION"
                                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10;
                                          -fx-font-weight: bold; -fx-padding: 0 0 12 0;"/>
                            <Label fx:id="coachApplicationStatus" text="Pending Review"
                                   style="-fx-background-color: rgba(246,173,85,0.1);
                                          -fx-border-color: rgba(246,173,85,0.3); -fx-border-width: 0 0 0 3;
                                          -fx-text-fill: #f6a825; -fx-font-size: 12;
                                          -fx-font-weight: bold; -fx-padding: 10 14;"/>
                            <Button fx:id="reapplyBtn" text="↩  Submit New Application"
                                    visible="false" managed="false"
                                    maxWidth="1.7976931348623157E308" onAction="#goToApplyCoach"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: rgba(232,55,42,0.35); -fx-border-width: 1;
                                           -fx-border-radius: 7; -fx-background-radius: 7;
                                           -fx-text-fill: #e8372a; -fx-font-size: 12;
                                           -fx-font-weight: bold; -fx-padding: 10 0; -fx-cursor: hand;"/>
                        </VBox>

                    </VBox>

                    <!-- ════ RIGHT COLUMN ════ -->
                    <VBox HBox.hgrow="ALWAYS" spacing="16">

                        <!-- Coins Card -->
                        <HBox spacing="0"
                              style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(246,216,96,0.2); -fx-border-width: 1;
                                     -fx-border-radius: 12; -fx-background-radius: 12;
                                     -fx-padding: 22 26;">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🪙" style="-fx-font-size: 16;"/>
                                    <Label text="EyeTwin Coins"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                </HBox>
                                <Label text="Use coins to access exclusive coaching live streams"
                                       style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 12;"/>
                            </VBox>
                            <VBox alignment="CENTER_RIGHT" spacing="4">
                                <Label fx:id="coinBalanceLabel" text="0"
                                       style="-fx-text-fill: #f6d860; -fx-font-family: 'Arial Black';
                                              -fx-font-size: 38; -fx-font-weight: bold;"/>
                                <Label text="coins available"
                                       style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11;"/>
                                <Button text="＋  Buy More Coins" onAction="#goToCoins"
                                        style="-fx-background-color: linear-gradient(90deg,#f6d860,#f6ad55);
                                               -fx-text-fill: #1a1a2e; -fx-font-size: 12;
                                               -fx-font-weight: bold; -fx-background-radius: 20;
                                               -fx-padding: 8 18; -fx-border-width: 0; -fx-cursor: hand;"/>
                            </VBox>
                        </HBox>

                        <!-- Game Statistics — Teams only (Achievements & Rating removed) -->
                        <VBox style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(232,55,42,0.18); -fx-border-width: 1;
                                     -fx-border-radius: 12; -fx-background-radius: 12;
                                     -fx-padding: 22 26;">
                            <Label text="GAME STATISTICS"
                                   style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 10;
                                          -fx-font-weight: bold; -fx-padding: 0 0 18 0;"/>
                            <HBox spacing="14">
                                <!-- Teams Joined -->
                                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8"
                                      style="-fx-background-color: rgba(255,255,255,0.03);
                                             -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1;
                                             -fx-border-radius: 9; -fx-background-radius: 9;
                                             -fx-padding: 18 10;">
                                    <Label text="👥" style="-fx-font-size: 22;"/>
                                    <Label fx:id="teamsCountLabel" text="0"
                                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                                  -fx-font-size: 26; -fx-font-weight: bold;"/>
                                    <Label text="Teams Joined"
                                           style="-fx-text-fill: rgba(255,255,255,0.38);
                                                  -fx-font-size: 10; -fx-font-weight: bold;"/>
                                </VBox>
                                <!-- Teams Owned -->
                                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8"
                                      style="-fx-background-color: rgba(255,255,255,0.03);
                                             -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1;
                                             -fx-border-radius: 9; -fx-background-radius: 9;
                                             -fx-padding: 18 10;">
                                    <Label text="👑" style="-fx-font-size: 22;"/>
                                    <Label fx:id="ownedTeamsLabel" text="0"
                                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                                  -fx-font-size: 26; -fx-font-weight: bold;"/>
                                    <Label text="Teams Owned"
                                           style="-fx-text-fill: rgba(255,255,255,0.38);
                                                  -fx-font-size: 10; -fx-font-weight: bold;"/>
                                </VBox>
                            </HBox>

                            <!-- View full stats link -->
                            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 14 0 0 0;">
                                <Label text="View Full Statistics →" onMouseClicked="#goToStatistics"
                                       style="-fx-text-fill: #e8372a; -fx-font-size: 11;
                                              -fx-font-weight: bold; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <!-- Account Information -->
                        <VBox style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(232,55,42,0.18); -fx-border-width: 1;
                                     -fx-border-radius: 12; -fx-background-radius: 12;
                                     -fx-padding: 22 26;">
                            <Label text="ℹ  ACCOUNT INFORMATION"
                                   style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 10;
                                          -fx-font-weight: bold; -fx-padding: 0 0 16 0;"/>

                            <HBox style="-fx-padding: 10 0;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 0 0 1 0;">
                                <Label text="Member since"
                                       style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 12;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="memberSinceLabel" text="—"
                                       style="-fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            </HBox>
                            <HBox style="-fx-padding: 10 0;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 0 0 1 0;">
                                <Label text="Last login"
                                       style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 12;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lastLoginLabel" text="—"
                                       style="-fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            </HBox>
                            <HBox style="-fx-padding: 10 0;">
                                <Label text="EyeTwin Coins"
                                       style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 12;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="5" alignment="CENTER">
                                    <Label text="🪙" style="-fx-font-size: 13;"/>
                                    <Label fx:id="coinsInfoLabel" text="0"
                                           style="-fx-text-fill: #f6d860; -fx-font-size: 13; -fx-font-weight: bold;"/>
                                </HBox>
                            </HBox>
                        </VBox>

                    </VBox>
                </HBox>

                <!-- ── FOOTER ── -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: #0d0c1a;
                             -fx-border-color: rgba(232,55,42,0.12);
                             -fx-border-width: 1 0 0 0; -fx-padding: 16 40;">
                    <Label text="EYETWIN"
                           style="-fx-text-fill: #ff4d3d; -fx-font-weight:bold;
                                  -fx-font-size:12; -fx-font-family:'Arial Black';"/>
                    <Label text="  ·  Copyright © 2025 — All Rights Reserved"
                           style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size:11;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
