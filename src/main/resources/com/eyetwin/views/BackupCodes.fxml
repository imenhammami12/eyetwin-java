<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.BackupCodesController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #06050f;"
            prefWidth="1280" prefHeight="800">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox style="-fx-background-color: #06050f;">

                <!-- ══ TOP NAV BAR ══ -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: rgba(255,255,255,0.025);
                             -fx-border-color: rgba(232,55,42,0.2);
                             -fx-border-width: 0 0 1 0; -fx-padding: 12 48;">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <!-- Real logo -->
                        <ImageView fitHeight="36" preserveRatio="true" pickOnBounds="true"
                                   onMouseClicked="#goHome" style="-fx-cursor: hand;">
                            <image><Image url="@../assets/img/eyetwin-logo.png"/></image>
                        </ImageView>
                        <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 14; -fx-padding: 0 2;"/>
                        <Label text="Security"
                               style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 13;"/>
                        <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 14; -fx-padding: 0 2;"/>
                        <Label text="Backup Codes"
                               style="-fx-text-fill: #e8372a; -fx-font-size: 13; -fx-font-weight: bold;"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#goHome" text="← Back"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: rgba(232,55,42,0.45); -fx-border-width: 1;
                                   -fx-border-radius: 6; -fx-background-radius: 6;
                                   -fx-text-fill: #e8372a; -fx-font-size: 12; -fx-font-weight: bold;
                                   -fx-padding: 7 16; -fx-cursor: hand;"/>
                </HBox>

                <!-- ══ PAGE CONTENT ══ -->
                <VBox style="-fx-padding: 32 80 52 80; -fx-spacing: 20;">

                    <!-- ── HERO BANNER ── -->
                    <HBox spacing="20" alignment="CENTER_LEFT"
                          style="-fx-background-color: #0c0a19;
                                 -fx-border-color: rgba(246,216,96,0.3);
                                 -fx-border-width: 1 1 1 4;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 22 28;">
                        <StackPane style="-fx-background-color: rgba(246,216,96,0.1);
                                          -fx-border-color: rgba(246,216,96,0.25); -fx-border-width: 1;
                                          -fx-border-radius: 50; -fx-background-radius: 50;
                                          -fx-min-width: 52; -fx-min-height: 52;
                                          -fx-max-width: 52; -fx-max-height: 52;">
                            <Label text="🛡" style="-fx-font-size: 24;"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="Backup Codes Secured"
                                   style="-fx-text-fill: #f6d860; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 22; -fx-font-weight: bold;"/>
                            <Label text="Your emergency access codes are ready — keep them safe!"
                                   style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="7" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(246,216,96,0.09);
                                     -fx-border-color: rgba(246,216,96,0.28); -fx-border-width: 1;
                                     -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-padding: 5 14;">
                            <Region style="-fx-background-color: #f6d860; -fx-background-radius: 50;
                                           -fx-min-width: 7; -fx-min-height: 7;
                                           -fx-max-width: 7; -fx-max-height: 7;"/>
                            <Label text="SECURED"
                                   style="-fx-text-fill: #f6d860; -fx-font-size: 10; -fx-font-weight: bold;"/>
                        </HBox>
                    </HBox>

                    <!-- ── SUCCESS BANNER (is_new=true) ── -->
                    <HBox fx:id="successBanner" visible="false" managed="false"
                          spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(0,230,118,0.07);
                                 -fx-border-color: rgba(0,230,118,0.35);
                                 -fx-border-width: 0 0 0 3; -fx-padding: 14 18;">
                        <Label text="✓" style="-fx-font-size: 18; -fx-text-fill: #00e676; -fx-font-weight: bold;"/>
                        <VBox spacing="2">
                            <Label text="2FA Successfully Enabled!"
                                   style="-fx-text-fill: #00e676; -fx-font-weight: bold; -fx-font-size: 13;"/>
                            <Label text="Two-factor authentication is now active on your account."
                                   style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12;"/>
                        </VBox>
                    </HBox>

                    <!-- ── CRITICAL WARNING ── -->
                    <HBox spacing="16" alignment="TOP_LEFT"
                          style="-fx-background-color: rgba(232,55,42,0.07);
                                 -fx-border-color: rgba(232,55,42,0.45);
                                 -fx-border-width: 0 0 0 3; -fx-padding: 16 20;">
                        <StackPane style="-fx-background-color: rgba(232,55,42,0.15);
                                          -fx-border-color: rgba(232,55,42,0.3); -fx-border-width: 1;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-min-width: 36; -fx-min-height: 36;
                                          -fx-max-width: 36; -fx-max-height: 36;">
                            <Label text="⚠" style="-fx-text-fill: #ff5545; -fx-font-size: 16;"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="Critical Security Notice"
                                   style="-fx-text-fill: #ff5545; -fx-font-weight: bold; -fx-font-size: 13;"/>
                            <Label text="Save these codes immediately. Each code can only be used ONCE. They are your only recovery method if you lose your authenticator device."
                                   wrapText="true"
                                   style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12;
                                          -fx-line-spacing: 2;"/>
                        </VBox>
                    </HBox>

                    <!-- ── CODES CONTAINER ── -->
                    <VBox style="-fx-background-color: #0c0a19;
                                 -fx-border-color: rgba(232,55,42,0.22);
                                 -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;">

                        <!-- Header bar -->
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-background-color: #e8372a;
                                     -fx-padding: 16 22;
                                     -fx-background-radius: 9 9 0 0;">
                            <Label text="🔑" style="-fx-font-size: 16;"/>
                            <Label fx:id="codesCountLabel" text="Your Backup Codes"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-weight: bold; -fx-font-size: 14;
                                          -fx-padding: 0 0 0 10;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="copyAllBtn" text="⎘  Copy All" onAction="#handleCopyAll"
                                    style="-fx-background-color: rgba(255,255,255,0.15);
                                           -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 1;
                                           -fx-border-radius: 6; -fx-background-radius: 6;
                                           -fx-text-fill: white; -fx-font-weight: bold;
                                           -fx-font-size: 12; -fx-padding: 7 16; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Codes list (built dynamically by controller) -->
                        <VBox fx:id="codesContainer" spacing="8"
                              style="-fx-padding: 20 22;"/>
                    </VBox>

                    <!-- ── ACTION BUTTONS ── -->
                    <HBox spacing="14">
                        <Button text="🖨  Print Codes"
                                maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: transparent;
                                       -fx-border-color: rgba(255,107,43,0.4); -fx-border-width: 1;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-text-fill: #ff6b2b; -fx-font-weight: bold;
                                       -fx-font-size: 13; -fx-padding: 13 0; -fx-cursor: hand;"/>
                        <Button fx:id="downloadBtn" text="⬇  Download as Text"
                                maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"
                                onAction="#handleDownload"
                                style="-fx-background-color: transparent;
                                       -fx-border-color: rgba(56,164,255,0.4); -fx-border-width: 1;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-text-fill: #38a4ff; -fx-font-weight: bold;
                                       -fx-font-size: 13; -fx-padding: 13 0; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- ── TIPS CARD ── -->
                    <VBox style="-fx-background-color: rgba(0,229,255,0.04);
                                 -fx-border-color: rgba(0,229,255,0.2);
                                 -fx-border-width: 0 0 0 3; -fx-padding: 18 22;">
                        <Label text="💡  Tips for Storing Backup Codes"
                               style="-fx-text-fill: #00e5ff; -fx-font-weight: bold;
                                      -fx-font-size: 13; -fx-padding: 0 0 12 0;"/>
                        <HBox spacing="10" style="-fx-padding: 5 0;">
                            <Label text="✓" style="-fx-text-fill: #00e676; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            <Label text="Save them in a password manager (recommended)"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12;"/>
                        </HBox>
                        <HBox spacing="10" style="-fx-padding: 5 0;">
                            <Label text="✓" style="-fx-text-fill: #00e676; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            <Label text="Print them and store in a safe or secure location"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12;"/>
                        </HBox>
                        <HBox spacing="10" style="-fx-padding: 5 0;">
                            <Label text="✓" style="-fx-text-fill: #00e676; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            <Label text="Take a screenshot and store it in an encrypted folder"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12;"/>
                        </HBox>
                        <HBox spacing="10" style="-fx-padding: 5 0;">
                            <Label text="✕" style="-fx-text-fill: #ff5545; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            <Label text="Never share them with anyone, even support staff"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12;"/>
                        </HBox>
                        <HBox spacing="10" style="-fx-padding: 5 0;">
                            <Label text="✕" style="-fx-text-fill: #ff5545; -fx-font-size: 12; -fx-font-weight: bold;"/>
                            <Label text="Don't store them in plain text on your computer"
                                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12;"/>
                        </HBox>
                    </VBox>

                    <!-- ── FINAL BUTTONS ── -->
                    <VBox spacing="10">
                        <Button fx:id="savedBtn" text="✓  I've Saved My Backup Codes"
                                maxWidth="1.7976931348623157E308" onAction="#handleSaved"
                                style="-fx-background-color: linear-gradient(135deg, #00e5ff, #00bcd4);
                                       -fx-text-fill: #06050f; -fx-font-weight: bold;
                                       -fx-font-family: 'Arial Black';
                                       -fx-font-size: 14; -fx-background-radius: 10;
                                       -fx-padding: 16 0; -fx-cursor: hand; -fx-border-width: 0;"/>
                        <Button fx:id="dashboardBtn" text="← Go to Home"
                                maxWidth="1.7976931348623157E308" onAction="#handleDashboard"
                                style="-fx-background-color: transparent;
                                       -fx-border-color: rgba(232,55,42,0.35); -fx-border-width: 1;
                                       -fx-border-radius: 10; -fx-background-radius: 10;
                                       -fx-text-fill: #e8372a; -fx-font-weight: bold;
                                       -fx-font-size: 13; -fx-padding: 13 0; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- ── TOAST ── -->
                    <VBox fx:id="toastBox" visible="false" managed="false"
                          style="-fx-background-color: #00bcd4;
                                 -fx-padding: 14 22; -fx-background-radius: 8;">
                        <Label fx:id="toastLabel" text=""
                               style="-fx-text-fill: #06050f; -fx-font-weight: bold; -fx-font-size: 12;"/>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
