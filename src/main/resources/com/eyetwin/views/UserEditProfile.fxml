<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.Circle?>

<!--
    UserEditProfile.fxml
    Mirrors: user/edit_profile.html.twig
    Controller: com.eyetwin.controller.UserEditProfileController
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.UserEditProfileController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #06050f;"
            prefWidth="1280" prefHeight="800">

    <!-- ══ NAVBAR — logo + profile dropdown only ══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: rgba(8,8,16,0.97);
                     -fx-border-color: rgba(232,55,42,0.15);
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24; -fx-pref-height: 64;">

            <!-- Logo -->
            <ImageView fitHeight="38" preserveRatio="true" pickOnBounds="true"
                       onMouseClicked="#goHome" style="-fx-cursor: hand;">
                <image><Image url="@../assets/img/eyetwin-logo.png"/></image>
            </ImageView>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Right zone: coins + profile dropdown -->
            <HBox fx:id="loggedInZone" alignment="CENTER" spacing="8" visible="true" managed="true">
                <HBox alignment="CENTER" spacing="6" onMouseClicked="#goToCoins"
                      style="-fx-background-color: linear-gradient(90deg,#f6d860,#f6ad55);
                             -fx-background-radius: 20; -fx-padding: 5 13; -fx-cursor: hand;">
                    <Label text="🪙" style="-fx-font-size: 11;"/>
                    <Label fx:id="coinsNavLabel" text="0"
                           style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #1a1a2e;"/>
                </HBox>
                <MenuButton fx:id="navProfileMenu"
                            style="-fx-background-color: rgba(255,255,255,0.03);
                                   -fx-border-color: rgba(232,55,42,0.18);
                                   -fx-border-radius: 50; -fx-background-radius: 50;
                                   -fx-padding: 4 12 4 4;
                                   -fx-mark-color: rgba(255,255,255,0.3); -fx-cursor: hand;">
                    <graphic>
                        <HBox alignment="CENTER" spacing="7">
                            <StackPane style="-fx-background-color: linear-gradient(135deg,#b02b20,#ff4d3d);
                                              -fx-background-radius: 50;
                                              -fx-min-width: 28; -fx-min-height: 28;
                                              -fx-max-width: 28; -fx-max-height: 28;">
                                <Label fx:id="navAvatarInitial" text="A"
                                       style="-fx-text-fill: white; -fx-font-weight:900; -fx-font-size:12;"/>
                            </StackPane>
                            <Label fx:id="navUsername" text="PLAYER"
                                   style="-fx-text-fill: white; -fx-font-weight:bold; -fx-font-size:10;"/>
                            <Label text="●" style="-fx-text-fill: #00e676; -fx-font-size: 7;"/>
                        </HBox>
                    </graphic>
                    <items>
                        <MenuItem text="👤  My Profile"       onAction="#goToProfile"    style="-fx-font-size:11;"/>
                        <MenuItem text="✏  Edit Profile"      onAction="#goToEditProfile" style="-fx-font-size:11;"/>
                        <MenuItem text="🛡  Two-Factor Auth"  onAction="#goTo2FA"         style="-fx-font-size:11;"/>
                        <MenuItem text="🎧  Support"          onAction="#goToSupport"     style="-fx-font-size:11;"/>
                        <SeparatorMenuItem/>
                        <MenuItem fx:id="profileAdminItem" text="⚙  Administration" visible="false"
                                  onAction="#goToAdmin"
                                  style="-fx-font-size:11; -fx-text-fill:#f6d860;"/>
                        <SeparatorMenuItem fx:id="profileAdminSep" visible="false"/>
                        <MenuItem text="🚪  Logout" onAction="#handleLogout"
                                  style="-fx-font-size:11; -fx-text-fill:#ff4d3d;"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox style="-fx-background-color: #06050f;">

                <!-- Page hero -->
                <VBox style="-fx-padding: 36 80 28 80;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-border-width: 0 0 1 0;">
                    <Label text="Edit My Profile"
                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                  -fx-font-size: 28; -fx-font-weight: bold;"/>
                    <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 4 0 0 0;">
                        <Label text="Home" onMouseClicked="#goHome"
                               style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 12; -fx-cursor: hand;"/>
                        <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 12;"/>
                        <Label text="Profile" onMouseClicked="#goToProfile"
                               style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 12; -fx-cursor: hand;"/>
                        <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 12;"/>
                        <Label text="Edit"
                               style="-fx-text-fill: #e8372a; -fx-font-size: 12;"/>
                    </HBox>
                </VBox>

                <!-- Flash messages -->
                <VBox fx:id="flashSuccessBox" visible="false" managed="false"
                      style="-fx-padding: 16 80 0 80;">
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(0,230,118,0.07);
                                 -fx-border-color: rgba(0,230,118,0.35);
                                 -fx-border-width: 0 0 0 3; -fx-padding: 12 16;">
                        <Label text="✓" style="-fx-text-fill: #00e676; -fx-font-size: 16; -fx-font-weight: bold;"/>
                        <Label fx:id="flashSuccessLabel" text=""
                               style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12;"/>
                    </HBox>
                </VBox>
                <VBox fx:id="flashErrorBox" visible="false" managed="false"
                      style="-fx-padding: 16 80 0 80;">
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(244,74,64,0.07);
                                 -fx-border-color: rgba(244,74,64,0.4);
                                 -fx-border-width: 0 0 0 3; -fx-padding: 12 16;">
                        <Label text="⚠" style="-fx-text-fill: #ff5545; -fx-font-size: 14;"/>
                        <Label fx:id="flashErrorLabel" text=""
                               style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12;"/>
                    </HBox>
                </VBox>

                <!-- Main layout -->
                <HBox spacing="24" style="-fx-padding: 28 80 48 80;" alignment="TOP_LEFT">

                    <!-- ════ LEFT — Profile Preview Card ════ -->
                    <VBox style="-fx-min-width: 280; -fx-pref-width: 280; -fx-max-width: 280;
                                 -fx-background-color: #0c0a19;
                                 -fx-border-color: rgba(232,55,42,0.2); -fx-border-width: 1;
                                 -fx-border-radius: 12; -fx-background-radius: 12;">

                        <!-- Preview header -->
                        <HBox alignment="CENTER_LEFT" spacing="8"
                              style="-fx-padding: 14 20;
                                     -fx-background-color: rgba(232,55,42,0.08);
                                     -fx-border-color: rgba(232,55,42,0.15);
                                     -fx-border-width: 0 0 1 0;
                                     -fx-background-radius: 12 12 0 0;">
                            <Label text="👁" style="-fx-font-size: 13;"/>
                            <Label text="PROFILE PREVIEW"
                                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10;
                                          -fx-font-weight: bold;"/>
                        </HBox>

                        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 28 20 22 20;">

                            <!-- Avatar preview -->
                            <StackPane>
                                <ImageView fx:id="previewImageView" fitWidth="90" fitHeight="90"
                                           preserveRatio="false" smooth="true"
                                           visible="false" managed="false">
                                    <clip>
                                        <Circle centerX="45" centerY="45" radius="45"/>
                                    </clip>
                                </ImageView>
                                <StackPane fx:id="previewPlaceholder"
                                           style="-fx-background-color: linear-gradient(135deg,#b02b20,#ff4d3d);
                                                  -fx-background-radius: 50;
                                                  -fx-min-width: 90; -fx-min-height: 90;
                                                  -fx-max-width: 90; -fx-max-height: 90;">
                                    <Label fx:id="previewInitial" text="A"
                                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                                  -fx-font-size: 34; -fx-font-weight: bold;"/>
                                </StackPane>
                            </StackPane>

                            <Label fx:id="previewUsername" text="USERNAME"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 16; -fx-font-weight: bold;"/>
                            <Label fx:id="previewEmail" text="user@email.com"
                                   style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 12;"/>

                            <!-- Fixed: merged two style= into one -->
                            <VBox spacing="6"
                                  style="-fx-padding: 12 0 0 0;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 1 0 0 0;">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="👥" style="-fx-font-size: 13;"/>
                                    <Label fx:id="previewTeamsLabel" text="0 Teams"
                                           style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="📅" style="-fx-font-size: 13;"/>
                                    <Label fx:id="previewMemberSince" text="Member since 2025"
                                           style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12;"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>

                    <!-- ════ RIGHT — Edit Form ════ -->
                    <VBox HBox.hgrow="ALWAYS" spacing="0"
                          style="-fx-background-color: #0c0a19;
                                 -fx-border-color: rgba(232,55,42,0.2); -fx-border-width: 1;
                                 -fx-border-radius: 12; -fx-background-radius: 12;">

                        <!-- Form header -->
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding: 18 26;
                                     -fx-border-color: rgba(255,255,255,0.05);
                                     -fx-border-width: 0 0 1 0;">
                            <Label text="✏" style="-fx-font-size: 16; -fx-text-fill: #e8372a;"/>
                            <Label text="EDIT MY INFORMATION"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 14; -fx-font-weight: bold;"/>
                        </HBox>

                        <VBox spacing="0" style="-fx-padding: 26 28;">

                            <!-- ── Section: Profile Picture ── -->
                            <VBox spacing="12" style="-fx-padding: 0 0 24 0;
                                                       -fx-border-color: rgba(255,255,255,0.05);
                                                       -fx-border-width: 0 0 1 0;">
                                <Label text="🖼  Profile Picture"
                                       style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10;
                                              -fx-font-weight: bold;"/>

                                <!-- Upload area -->
                                <VBox fx:id="uploadArea" alignment="CENTER" spacing="10"
                                      onMouseClicked="#handlePickProfilePicture"
                                      style="-fx-background-color: rgba(232,55,42,0.04);
                                             -fx-border-color: rgba(232,55,42,0.25);
                                             -fx-border-width: 1.5; -fx-border-style: dashed;
                                             -fx-border-radius: 10; -fx-background-radius: 10;
                                             -fx-padding: 26; -fx-cursor: hand;">
                                    <Label text="☁" style="-fx-font-size: 32; -fx-text-fill: rgba(232,55,42,0.5);"/>
                                    <Label text="Click to upload a new profile picture"
                                           style="-fx-text-fill: rgba(232,55,42,0.8); -fx-font-size: 13;
                                                  -fx-font-weight: bold;"/>
                                    <Label text="or drag and drop your image here"
                                           style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11;"/>
                                </VBox>

                                <Label fx:id="selectedFileLabel" text=""
                                       visible="false" managed="false"
                                       style="-fx-text-fill: #00e676; -fx-font-size: 11;"/>

                                <HBox alignment="CENTER_LEFT" spacing="7">
                                    <Label text="ℹ" style="-fx-text-fill: rgba(56,164,255,0.7); -fx-font-size: 13;"/>
                                    <Label text="Accepted formats: JPG, PNG, WEBP (max 2MB)"
                                           style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11;"/>
                                </HBox>
                            </VBox>

                            <!-- ── Section: Personal Information ── -->
                            <VBox spacing="16" style="-fx-padding: 22 0 24 0;
                                                       -fx-border-color: rgba(255,255,255,0.05);
                                                       -fx-border-width: 0 0 1 0;">
                                <Label text="👤  Personal Information"
                                       style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10;
                                              -fx-font-weight: bold;"/>

                                <HBox spacing="16">
                                    <!-- Username (readonly) -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="7">
                                        <Label text="Username"
                                               style="-fx-text-fill: rgba(255,255,255,0.55);
                                                      -fx-font-size: 12; -fx-font-weight: bold;"/>
                                        <HBox spacing="0" alignment="CENTER_LEFT"
                                              style="-fx-background-color: rgba(255,255,255,0.03);
                                                     -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1;
                                                     -fx-border-radius: 8; -fx-background-radius: 8;">
                                            <Label text="👤"
                                                   style="-fx-font-size: 13; -fx-padding: 0 10 0 14;
                                                          -fx-text-fill: rgba(255,255,255,0.25);"/>
                                            <TextField fx:id="usernameField" editable="false"
                                                       HBox.hgrow="ALWAYS"
                                                       style="-fx-background-color: transparent;
                                                              -fx-text-fill: rgba(255,255,255,0.4);
                                                              -fx-font-size: 13; -fx-border-width: 0;
                                                              -fx-padding: 12 14 12 0;"/>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="5">
                                            <Label text="🔒" style="-fx-font-size: 11;"/>
                                            <Label text="Username cannot be changed"
                                                   style="-fx-text-fill: rgba(255,255,255,0.25);
                                                          -fx-font-size: 11;"/>
                                        </HBox>
                                    </VBox>

                                    <!-- Email -->
                                    <VBox HBox.hgrow="ALWAYS" spacing="7">
                                        <Label text="Email"
                                               style="-fx-text-fill: rgba(255,255,255,0.55);
                                                      -fx-font-size: 12; -fx-font-weight: bold;"/>
                                        <HBox spacing="0" alignment="CENTER_LEFT"
                                              style="-fx-background-color: rgba(255,255,255,0.04);
                                                     -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1;
                                                     -fx-border-radius: 8; -fx-background-radius: 8;">
                                            <Label text="✉"
                                                   style="-fx-font-size: 13; -fx-padding: 0 10 0 14;
                                                          -fx-text-fill: rgba(255,255,255,0.3);"/>
                                            <TextField fx:id="emailField" promptText="your@email.com"
                                                       HBox.hgrow="ALWAYS"
                                                       style="-fx-background-color: transparent;
                                                              -fx-text-fill: white; -fx-font-size: 13;
                                                              -fx-border-width: 0; -fx-padding: 12 14 12 0;"/>
                                        </HBox>
                                        <Label fx:id="emailErrorLabel" text="" visible="false" managed="false"
                                               style="-fx-background-color: rgba(244,74,64,0.08);
                                                      -fx-border-color: rgba(244,74,64,0.3);
                                                      -fx-border-width: 0 0 0 3; -fx-padding: 8 12;
                                                      -fx-text-fill: #ff7060; -fx-font-size: 11;
                                                      -fx-font-weight: bold;"/>
                                    </VBox>
                                </HBox>

                                <!-- Full Name -->
                                <VBox spacing="7">
                                    <Label text="Full Name"
                                           style="-fx-text-fill: rgba(255,255,255,0.55);
                                                  -fx-font-size: 12; -fx-font-weight: bold;"/>
                                    <HBox spacing="0" alignment="CENTER_LEFT"
                                          style="-fx-background-color: rgba(255,255,255,0.04);
                                                 -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1;
                                                 -fx-border-radius: 8; -fx-background-radius: 8;">
                                        <Label text="🪪"
                                               style="-fx-font-size: 13; -fx-padding: 0 10 0 14;
                                                      -fx-text-fill: rgba(255,255,255,0.3);"/>
                                        <TextField fx:id="fullNameField" promptText="John Doe"
                                                   maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: transparent;
                                                          -fx-text-fill: white; -fx-font-size: 13;
                                                          -fx-border-width: 0; -fx-padding: 12 14 12 0;"/>
                                    </HBox>
                                    <Label fx:id="fullNameErrorLabel" text="" visible="false" managed="false"
                                           style="-fx-text-fill: #ff7060; -fx-font-size: 11;"/>
                                </VBox>
                            </VBox>

                            <!-- ── Section: Bio ── -->
                            <VBox spacing="12" style="-fx-padding: 22 0 28 0;">
                                <Label text="✏  About Me"
                                       style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10;
                                              -fx-font-weight: bold;"/>
                                <Label text="Biography"
                                       style="-fx-text-fill: rgba(255,255,255,0.55);
                                              -fx-font-size: 12; -fx-font-weight: bold;"/>
                                <VBox spacing="0"
                                      style="-fx-background-color: rgba(255,255,255,0.04);
                                             -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1;
                                             -fx-border-radius: 8; -fx-background-radius: 8;">
                                    <TextArea fx:id="bioField"
                                              promptText="Tell us about yourself, your gaming experience, your favorite games..."
                                              prefRowCount="5"
                                              wrapText="true"
                                              style="-fx-background-color: transparent;
                                                     -fx-text-fill: white; -fx-font-size: 13;
                                                     -fx-border-width: 0; -fx-padding: 12 14;
                                                     -fx-prompt-text-fill: rgba(255,255,255,0.2);"/>
                                    <HBox alignment="CENTER_RIGHT"
                                          style="-fx-background-color: rgba(255,255,255,0.02);
                                                 -fx-border-color: rgba(255,255,255,0.05);
                                                 -fx-border-width: 1 0 0 0; -fx-padding: 6 14;">
                                        <Label fx:id="bioCharCounter" text="0 / 500 characters"
                                               style="-fx-text-fill: rgba(255,255,255,0.28);
                                                      -fx-font-size: 11;"/>
                                    </HBox>
                                </VBox>
                                <Label fx:id="bioErrorLabel" text="" visible="false" managed="false"
                                       style="-fx-text-fill: #ff7060; -fx-font-size: 11;"/>
                            </VBox>

                            <!-- ── Action Buttons ── -->
                            <HBox spacing="12" alignment="CENTER_RIGHT">
                                <Button text="✕  Cancel" onAction="#goToProfile"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                               -fx-border-radius: 8; -fx-background-radius: 8;
                                               -fx-text-fill: rgba(255,255,255,0.55);
                                               -fx-font-size: 13; -fx-font-weight: bold;
                                               -fx-padding: 13 24; -fx-cursor: hand;"/>
                                <Button fx:id="saveBtn" text="💾  Save Changes" onAction="#handleSave"
                                        style="-fx-background-color: #e8372a; -fx-border-width: 0;
                                               -fx-text-fill: white; -fx-font-size: 13;
                                               -fx-font-family: 'Arial Black';
                                               -fx-font-weight: bold; -fx-background-radius: 8;
                                               -fx-padding: 13 28; -fx-cursor: hand;"/>
                            </HBox>

                        </VBox>
                    </VBox>

                </HBox>

                <!-- Footer -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: #0d0c1a;
                             -fx-border-color: rgba(232,55,42,0.12);
                             -fx-border-width: 1 0 0 0; -fx-padding: 16 40;">
                    <Label text="EYETWIN"
                           style="-fx-text-fill: #ff4d3d; -fx-font-weight:bold;
                                  -fx-font-size:12; -fx-font-family:'Arial Black';"/>
                    <Label text="  ·  Copyright © 2025 — All Rights Reserved"
                           style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size:11;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
