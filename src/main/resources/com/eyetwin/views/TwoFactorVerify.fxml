<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<!--
    TwoFactorVerify.fxml
    Mirrors: two_factor/2fa.html.twig (Symfony)
    Controller: com.eyetwin.controller.TwoFactorVerifyController
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.TwoFactorVerifyController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #080810;"
            prefWidth="1280" prefHeight="800">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane">
            <VBox alignment="CENTER" style="-fx-background-color: #080810; -fx-padding: 60 0;">

                <!-- Card -->
                <VBox maxWidth="520"
                      style="-fx-background-color: linear-gradient(135deg, #1a1f2e, #0b111f);
                             -fx-border-color: rgba(255,0,0,0.25);
                             -fx-border-radius: 20; -fx-background-radius: 20;
                             -fx-border-width: 2;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 40, 0, 0, 10);
                             -fx-padding: 45 45 35 45;">

                    <!-- Header -->
                    <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 28 0;">
                        <Label text="🛡"
                               style="-fx-font-size: 46; -fx-effect: dropshadow(gaussian,rgba(255,0,0,0.4),20,0,0,0);"/>
                        <Label text="Two-Factor Authentication"
                               style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                      -fx-font-size: 22; -fx-font-weight: bold;"/>
                        <Label text="Enter the 6-digit code from your authenticator app"
                               style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12;"/>
                    </VBox>

                    <!-- Error box -->
                    <VBox fx:id="errorBox" visible="false" managed="false"
                          style="-fx-background-color: rgba(244,74,64,0.15);
                                 -fx-border-color: #f44a40; -fx-border-width: 0 0 0 4;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-padding: 12 16; -fx-margin: 0 0 20 0;">
                        <Label fx:id="errorLabel" text=""
                               style="-fx-text-fill: #f44a40; -fx-font-size: 12; -fx-wrap-text: true;"/>
                    </VBox>

                    <!-- TOTP input — auto-submits on 6 digits (like Symfony template) -->
                    <VBox spacing="8" style="-fx-padding: 0 0 20 0;">
                        <Label text="Authentication Code"
                               style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12; -fx-font-weight: bold;"/>
                        <TextField fx:id="totpCodeField"
                                   promptText="000000"
                                   maxWidth="1.7976931348623157E308"
                                   style="-fx-font-family: 'Courier New'; -fx-font-size: 28;
                                          -fx-font-weight: bold; -fx-letter-spacing: 0.5em;
                                          -fx-text-fill: white; -fx-alignment: CENTER;
                                          -fx-background-color: rgba(255,255,255,0.04);
                                          -fx-border-color: rgba(255,255,255,0.15);
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-padding: 18 0 18 0;"/>
                        <Label text="📱 Open your authenticator app to get your code"
                               style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11;"/>
                    </VBox>

                    <!-- Trust device checkbox -->
                    <CheckBox fx:id="trustedDeviceCheck"
                              text="Trust this device for 30 days"
                              style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12;
                                     -fx-padding: 0 0 20 0;"/>

                    <!-- Verify button -->
                    <Button fx:id="verifyBtn" text="✓  Verify"
                            maxWidth="1.7976931348623157E308"
                            onAction="#handleVerifyTotp"
                            style="-fx-background-color: linear-gradient(135deg, #ff0000, #c6019a);
                                   -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;
                                   -fx-background-radius: 12; -fx-padding: 16 0;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(255,0,0,0.4), 20, 0, 0, 5);"/>

                    <!-- Divider -->
                    <Separator style="-fx-padding: 20 0;"/>

                    <!-- Backup codes section (collapsed) -->
                    <VBox spacing="10" style="-fx-padding: 10 0 0 0;">
                        <VBox alignment="CENTER">
                            <Label text="Lost your device?"
                                   style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11;"/>
                            <Button fx:id="showBackupBtn" text="Use Backup Code"
                                    onAction="#handleShowBackupSection"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: rgba(255,255,255,0.2);
                                           -fx-border-radius: 8; -fx-background-radius: 8;
                                           -fx-text-fill: rgba(255,255,255,0.65);
                                           -fx-font-size: 12; -fx-font-weight: bold;
                                           -fx-padding: 9 20; -fx-cursor: hand;"/>
                        </VBox>

                        <!-- Backup code form (hidden by default) -->
                        <VBox fx:id="backupCodeSection" visible="false" managed="false"
                              style="-fx-background-color: rgba(255,255,255,0.03);
                                     -fx-border-color: rgba(255,255,255,0.1);
                                     -fx-border-radius: 12; -fx-background-radius: 12;
                                     -fx-border-width: 1; -fx-padding: 20;">
                            <Label text="Backup Code"
                                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12; -fx-font-weight: bold;"/>
                            <TextField fx:id="backupCodeField"
                                       promptText="XXXXX-XXXXX"
                                       style="-fx-text-fill: white; -fx-alignment: CENTER;
                                              -fx-background-color: rgba(255,255,255,0.04);
                                              -fx-border-color: rgba(255,255,255,0.15);
                                              -fx-border-radius: 8; -fx-background-radius: 8;
                                              -fx-border-width: 2; -fx-padding: 12; -fx-font-size: 16;
                                              -fx-font-family: 'Courier New';"/>
                            <Label text="Each backup code can only be used once"
                                   style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11; -fx-padding: 4 0 10 0;"/>
                            <Button fx:id="verifyBackupBtn" text="Verify Backup Code"
                                    maxWidth="1.7976931348623157E308"
                                    onAction="#handleVerifyBackup"
                                    style="-fx-background-color: rgba(255,255,255,0.08);
                                           -fx-border-color: rgba(255,255,255,0.2);
                                           -fx-border-radius: 8; -fx-background-radius: 8;
                                           -fx-text-fill: white; -fx-font-weight: bold;
                                           -fx-font-size: 12; -fx-padding: 12; -fx-cursor: hand;"/>
                        </VBox>
                    </VBox>

                    <!-- Cancel / logout link -->
                    <VBox alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                        <Button fx:id="cancelBtn" text="← Cancel and Logout"
                                onAction="#handleCancel"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;
                                       -fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11;
                                       -fx-cursor: hand;"/>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
