<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<!--
    TwoFactorVerify.fxml
    Mirrors: two_factor/2fa.html.twig (Symfony)
    Controller: com.eyetwin.controller.TwoFactorVerifyController
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.TwoFactorVerifyController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #06050f;"
            prefWidth="1280" prefHeight="800">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane"
                    style="-fx-background-color: transparent; -fx-background: transparent;">

            <!-- Full-height split layout -->
            <HBox style="-fx-background-color: #06050f; -fx-min-height: 800;">

                <!-- ══ LEFT PANEL: Branding ══ -->
                <VBox alignment="CENTER" spacing="0"
                      style="-fx-background-color: #0c0a19;
                             -fx-border-color: rgba(232,55,42,0.2);
                             -fx-border-width: 0 1 0 0;
                             -fx-min-width: 380; -fx-pref-width: 380; -fx-max-width: 380;
                             -fx-padding: 60 48;">

                    <VBox spacing="20" alignment="CENTER_LEFT">
                        <!-- Logo -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="🛡" style="-fx-font-size: 24;"/>
                            <Label text="EYETWIN"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 18; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Divider -->
                        <Region style="-fx-background-color: rgba(232,55,42,0.3);
                                       -fx-pref-height: 1; -fx-max-width: 60;"/>

                        <VBox spacing="8">
                            <Label text="Verification Required"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 22; -fx-font-weight: bold;"/>
                            <Label text="Enter your 2FA code to continue to your account."
                                   wrapText="true"
                                   style="-fx-text-fill: rgba(255,255,255,0.42); -fx-font-size: 13;
                                          -fx-line-spacing: 3;"/>
                        </VBox>

                        <!-- Info box -->
                        <VBox spacing="16" style="-fx-padding: 24 0 0 0;">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="📱" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Open your authenticator app"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Get the 6-digit code"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="⏱" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Code refreshes every 30s"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Enter it before it expires"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="🔑" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Lost your device?"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Use a backup code instead"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>

                </VBox>

                <!-- ══ RIGHT PANEL: Form ══ -->
                <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
                      style="-fx-padding: 60 80;">

                    <VBox maxWidth="420" spacing="0">

                        <!-- Form header -->
                        <VBox spacing="4" style="-fx-padding: 0 0 28 0;
                                                  -fx-border-color: rgba(255,255,255,0.05);
                                                  -fx-border-width: 0 0 1 0;">
                            <Label text="Enter Authentication Code"
                                   style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                          -fx-font-size: 20; -fx-font-weight: bold;"/>
                            <Label text="6-digit code from your authenticator app"
                                   style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 12;"/>
                        </VBox>

                        <!-- Error box -->
                        <VBox fx:id="errorBox" visible="false" managed="false"
                              style="-fx-background-color: rgba(244,74,64,0.07);
                                     -fx-border-color: rgba(244,74,64,0.4);
                                     -fx-border-width: 0 0 0 3; -fx-padding: 11 14;
                                     -fx-margin: 0 0 16 0;">
                            <Label fx:id="errorLabel" text=""
                                   style="-fx-text-fill: #ff7060; -fx-font-size: 12;
                                          -fx-font-weight: bold; -fx-wrap-text: true;"/>
                        </VBox>

                        <!-- TOTP Input -->
                        <VBox spacing="8" style="-fx-padding: 24 0 20 0;">
                            <Label text="AUTHENTICATION CODE"
                                   style="-fx-text-fill: rgba(255,255,255,0.35);
                                          -fx-font-size: 10; -fx-font-weight: bold;"/>
                            <TextField fx:id="totpCodeField"
                                       promptText="000000"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-font-family: 'Courier New'; -fx-font-size: 32;
                                              -fx-font-weight: bold; -fx-text-fill: white;
                                              -fx-alignment: CENTER;
                                              -fx-prompt-text-fill: rgba(255,255,255,0.18);
                                              -fx-background-color: rgba(232,55,42,0.06);
                                              -fx-border-color: rgba(232,55,42,0.4);
                                              -fx-border-width: 1.5;
                                              -fx-border-radius: 10; -fx-background-radius: 10;
                                              -fx-padding: 18 0;"/>
                        </VBox>

                        <!-- Trust device -->
                        <CheckBox fx:id="trustedDeviceCheck"
                                  text="Trust this device for 30 days"
                                  style="-fx-text-fill: rgba(255,255,255,0.55);
                                         -fx-font-size: 12; -fx-padding: 0 0 22 0;"/>

                        <!-- Verify button -->
                        <Button fx:id="verifyBtn" text="✓  Verify and Continue"
                                maxWidth="1.7976931348623157E308"
                                onAction="#handleVerifyTotp"
                                style="-fx-background-color: #e8372a; -fx-border-width: 0;
                                       -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;
                                       -fx-background-radius: 10; -fx-padding: 16 0; -fx-cursor: hand;"/>

                        <!-- Separator -->
                        <Region style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-pref-height: 1; -fx-margin: 24 0;"/>

                        <!-- Backup section -->
                        <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                            <VBox alignment="CENTER" spacing="5">
                                <Label text="Lost your device?"
                                       style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11;"/>
                                <Button fx:id="showBackupBtn" text="Use a Backup Code"
                                        onAction="#handleShowBackupSection"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                               -fx-border-radius: 7; -fx-background-radius: 7;
                                               -fx-text-fill: rgba(255,255,255,0.55);
                                               -fx-font-size: 12; -fx-font-weight: bold;
                                               -fx-padding: 8 18; -fx-cursor: hand;"/>
                            </VBox>

                            <!-- Backup code form -->
                            <VBox fx:id="backupCodeSection" visible="false" managed="false"
                                  spacing="10"
                                  style="-fx-background-color: rgba(255,255,255,0.025);
                                         -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1;
                                         -fx-border-radius: 9; -fx-background-radius: 9;
                                         -fx-padding: 18;">
                                <Label text="BACKUP CODE"
                                       style="-fx-text-fill: rgba(255,255,255,0.3);
                                              -fx-font-size: 10; -fx-font-weight: bold;"/>
                                <TextField fx:id="backupCodeField"
                                           promptText="XXXXX-XXXXX"
                                           style="-fx-text-fill: white; -fx-alignment: CENTER;
                                                  -fx-background-color: rgba(255,255,255,0.04);
                                                  -fx-border-color: rgba(255,255,255,0.1);
                                                  -fx-border-width: 1; -fx-border-radius: 7;
                                                  -fx-background-radius: 7; -fx-padding: 12;
                                                  -fx-font-size: 15;
                                                  -fx-font-family: 'Courier New';
                                                  -fx-prompt-text-fill: rgba(255,255,255,0.2);"/>
                                <Label text="Each backup code can only be used once."
                                       style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11;"/>
                                <Button fx:id="verifyBackupBtn" text="Verify Backup Code"
                                        maxWidth="1.7976931348623157E308"
                                        onAction="#handleVerifyBackup"
                                        style="-fx-background-color: rgba(255,255,255,0.05);
                                               -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                               -fx-border-radius: 7; -fx-background-radius: 7;
                                               -fx-text-fill: rgba(255,255,255,0.75);
                                               -fx-font-weight: bold; -fx-font-size: 12;
                                               -fx-padding: 11; -fx-cursor: hand;"/>
                            </VBox>
                        </VBox>

                        <!-- Cancel -->
                        <VBox alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                            <Button fx:id="cancelBtn" text="← Cancel and Logout"
                                    onAction="#handleCancel"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: transparent;
                                           -fx-text-fill: rgba(255,255,255,0.28);
                                           -fx-font-size: 11; -fx-cursor: hand;"/>
                        </VBox>

                    </VBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
