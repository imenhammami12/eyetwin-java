<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.TwoFactorSettingsController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #06050f;"
            prefWidth="1280" prefHeight="800">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox style="-fx-background-color: #06050f;">

                <!-- ══ TOP NAV BAR ══ -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: rgba(255,255,255,0.025);
                             -fx-border-color: rgba(232,55,42,0.2);
                             -fx-border-width: 0 0 1 0;
                             -fx-padding: 16 48;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🛡" style="-fx-font-size: 16;"/>
                        <Label text="EYETWIN"
                               style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                      -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label text="›"
                               style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 14; -fx-padding: 0 2;"/>
                        <Label text="Security"
                               style="-fx-text-fill: #e8372a; -fx-font-size: 13; -fx-font-weight: bold;"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="backBtn" text="← Back" onAction="#handleBack"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: rgba(232,55,42,0.45);
                                   -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;
                                   -fx-text-fill: #e8372a; -fx-font-size: 12; -fx-font-weight: bold;
                                   -fx-padding: 7 16; -fx-cursor: hand;"/>
                </HBox>

                <!-- ══ HERO ══ -->
                <VBox style="-fx-padding: 44 80 32 80;
                             -fx-border-color: rgba(255,255,255,0.05);
                             -fx-border-width: 0 0 1 0;">
                    <Label text="Two-Factor Authentication"
                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                  -fx-font-size: 30; -fx-font-weight: bold;"/>
                    <Label text="Manage your account security settings"
                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 13;
                                  -fx-padding: 6 0 0 0;"/>
                </VBox>

                <!-- ══ FLASH MESSAGE ══ -->
                <VBox fx:id="flashBox" visible="false" managed="false"
                      style="-fx-padding: 16 80 0 80;">
                    <Label fx:id="flashMessage" text=""
                           maxWidth="1.7976931348623157E308"
                           style="-fx-font-size: 12; -fx-wrap-text: true;
                                  -fx-padding: 12 16; -fx-background-radius: 6; -fx-border-radius: 6;"/>
                </VBox>

                <!-- ══════════════════════════════════
                     ENABLED STATE
                ══════════════════════════════════ -->
                <VBox fx:id="enabledBanner" visible="false" managed="false"
                      style="-fx-padding: 28 80 48 80; -fx-spacing: 20;">

                    <!-- Status row -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <HBox spacing="7" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(0,230,118,0.09);
                                     -fx-border-color: rgba(0,230,118,0.28);
                                     -fx-border-width: 1; -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-padding: 5 14;">
                            <Region style="-fx-background-color: #00e676; -fx-background-radius: 50;
                                           -fx-min-width: 7; -fx-min-height: 7;
                                           -fx-max-width: 7; -fx-max-height: 7;"/>
                            <Label text="ACTIVE"
                                   style="-fx-text-fill: #00e676; -fx-font-size: 10; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label text="Your account is protected with 2FA"
                               style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 12;"/>
                    </HBox>

                    <!-- Cards -->
                    <HBox spacing="18">

                        <!-- Backup Codes Card -->
                        <VBox HBox.hgrow="ALWAYS" spacing="0"
                              style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(232,55,42,0.3);
                                     -fx-border-width: 1 1 1 4;
                                     -fx-border-radius: 10; -fx-background-radius: 10;
                                     -fx-padding: 26;">
                            <!-- Header -->
                            <HBox spacing="10" alignment="CENTER_LEFT"
                                  style="-fx-padding: 0 0 18 0;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 0 0 1 0;">
                                <Label text="🔑" style="-fx-font-size: 18;"/>
                                <VBox spacing="1">
                                    <Label text="Backup Codes"
                                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                                  -fx-font-size: 15; -fx-font-weight: bold;"/>
                                    <Label text="Emergency access codes"
                                           style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <!-- Body -->
                            <VBox spacing="14" style="-fx-padding: 18 0 0 0;">
                                <HBox>
                                    <Label fx:id="backupCodesCountLabel" text="— codes remaining"
                                           style="-fx-background-color: rgba(232,55,42,0.1);
                                                  -fx-border-color: rgba(232,55,42,0.35);
                                                  -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;
                                                  -fx-text-fill: #ff6b5b; -fx-font-size: 11;
                                                  -fx-font-weight: bold; -fx-padding: 4 11;"/>
                                </HBox>
                                <Label text="Emergency codes for when you can't access your authenticator app. Each code works once only."
                                       wrapText="true"
                                       style="-fx-text-fill: rgba(255,255,255,0.42); -fx-font-size: 12;
                                              -fx-line-spacing: 2;"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button fx:id="viewBackupCodesBtn" text="👁  View Codes"
                                        maxWidth="1.7976931348623157E308" onAction="#handleViewBackupCodes"
                                        style="-fx-background-color: #e8372a; -fx-border-width: 0;
                                               -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;
                                               -fx-background-radius: 8; -fx-padding: 13 0; -fx-cursor: hand;"/>
                                <Button fx:id="regenerateCodesBtn" text="⟳  Regenerate Codes"
                                        maxWidth="1.7976931348623157E308" onAction="#handleRegenerate"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1;
                                               -fx-border-radius: 8; -fx-background-radius: 8;
                                               -fx-text-fill: rgba(255,255,255,0.55);
                                               -fx-font-weight: bold; -fx-font-size: 12;
                                               -fx-padding: 11 0; -fx-cursor: hand;"/>
                            </VBox>
                        </VBox>

                        <!-- Disable 2FA Card -->
                        <VBox HBox.hgrow="ALWAYS" spacing="0"
                              style="-fx-background-color: #0c0a19;
                                     -fx-border-color: rgba(255,255,255,0.07);
                                     -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;
                                     -fx-padding: 26;">
                            <!-- Header -->
                            <HBox spacing="10" alignment="CENTER_LEFT"
                                  style="-fx-padding: 0 0 18 0;
                                         -fx-border-color: rgba(255,255,255,0.05);
                                         -fx-border-width: 0 0 1 0;">
                                <Label text="⚠" style="-fx-font-size: 16; -fx-text-fill: #f44a40;"/>
                                <VBox spacing="1">
                                    <Label text="Disable 2FA"
                                           style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                                  -fx-font-size: 15; -fx-font-weight: bold;"/>
                                    <Label text="Remove extra security layer"
                                           style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <!-- Body -->
                            <VBox spacing="14" style="-fx-padding: 18 0 0 0;">
                                <VBox style="-fx-background-color: rgba(244,74,64,0.07);
                                             -fx-border-color: rgba(244,74,64,0.25);
                                             -fx-border-width: 0 0 0 3; -fx-padding: 12 14;">
                                    <Label text="Disabling 2FA means anyone with your password can access your account. This is not recommended."
                                           wrapText="true"
                                           style="-fx-text-fill: rgba(255,160,150,0.88);
                                                  -fx-font-size: 12; -fx-line-spacing: 2;"/>
                                </VBox>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button fx:id="disableBtn" text="Disable Protection"
                                        maxWidth="1.7976931348623157E308" onAction="#handleDisable"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: rgba(244,74,64,0.45); -fx-border-width: 1.5;
                                               -fx-border-radius: 8; -fx-background-radius: 8;
                                               -fx-text-fill: #f44a40; -fx-font-weight: bold;
                                               -fx-font-size: 13; -fx-padding: 13 0; -fx-cursor: hand;"/>
                            </VBox>
                        </VBox>

                    </HBox>
                </VBox>

                <!-- ══════════════════════════════════
                     DISABLED STATE
                ══════════════════════════════════ -->
                <VBox fx:id="disabledBanner" visible="true" managed="true"
                      style="-fx-padding: 28 80 48 80; -fx-spacing: 20;">

                    <!-- Status row -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <HBox spacing="7" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(246,216,96,0.09);
                                     -fx-border-color: rgba(246,216,96,0.28);
                                     -fx-border-width: 1; -fx-border-radius: 20; -fx-background-radius: 20;
                                     -fx-padding: 5 14;">
                            <Region style="-fx-background-color: #f6d860; -fx-background-radius: 50;
                                           -fx-min-width: 7; -fx-min-height: 7;
                                           -fx-max-width: 7; -fx-max-height: 7;"/>
                            <Label text="NOT PROTECTED"
                                   style="-fx-text-fill: #f6d860; -fx-font-size: 10; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label text="Enable 2FA to protect your account"
                               style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 12;"/>
                    </HBox>

                    <!-- Split layout card -->
                    <HBox spacing="0"
                          style="-fx-background-color: #0c0a19;
                                 -fx-border-color: rgba(232,55,42,0.18);
                                 -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12;">

                        <!-- Left panel: benefits -->
                        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 30;
                                                          -fx-border-color: rgba(255,255,255,0.05);
                                                          -fx-border-width: 0 1 0 0;">
                            <Label text="WHY ENABLE 2FA"
                                   style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 10;
                                          -fx-font-weight: bold; -fx-padding: 0 0 18 0;"/>

                            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="🛡" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Enhanced Security"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Protected even if password is stolen"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="⚡" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="2-Minute Setup"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Quick and easy to configure"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="📴" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Works Offline"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Codes work without internet"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane style="-fx-background-color: rgba(0,229,255,0.08);
                                                  -fx-border-color: rgba(0,229,255,0.18); -fx-border-width: 1;
                                                  -fx-border-radius: 7; -fx-background-radius: 7;
                                                  -fx-min-width: 32; -fx-min-height: 32;
                                                  -fx-max-width: 32; -fx-max-height: 32;">
                                    <Label text="🔑" style="-fx-font-size: 14;"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Backup Codes"
                                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label text="Emergency access if device is lost"
                                           style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Right panel: CTA -->
                        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="20"
                              style="-fx-padding: 30;">
                            <VBox spacing="6" alignment="CENTER">
                                <Label text="You'll need"
                                       style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11;"/>
                                <Label text="An Authenticator App"
                                       style="-fx-text-fill: white; -fx-font-family: 'Arial Black';
                                              -fx-font-size: 16; -fx-font-weight: bold;"/>
                            </VBox>

                            <VBox spacing="7" maxWidth="240">
                                <HBox style="-fx-background-color: rgba(255,255,255,0.03);
                                             -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1;
                                             -fx-border-radius: 7; -fx-background-radius: 7;
                                             -fx-padding: 9 14;">
                                    <Label text="📱  Google Authenticator"
                                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12;"/>
                                </HBox>
                                <HBox style="-fx-background-color: rgba(255,255,255,0.03);
                                             -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1;
                                             -fx-border-radius: 7; -fx-background-radius: 7;
                                             -fx-padding: 9 14;">
                                    <Label text="🔐  Authy"
                                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12;"/>
                                </HBox>
                                <HBox style="-fx-background-color: rgba(255,255,255,0.03);
                                             -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1;
                                             -fx-border-radius: 7; -fx-background-radius: 7;
                                             -fx-padding: 9 14;">
                                    <Label text="🏢  Microsoft Authenticator"
                                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12;"/>
                                </HBox>
                            </VBox>

                            <Button fx:id="enableBtn" text="Enable 2FA Now →"
                                    maxWidth="240" onAction="#handleEnable"
                                    style="-fx-background-color: #e8372a; -fx-border-width: 0;
                                           -fx-text-fill: white; -fx-font-family: 'Arial Black';
                                           -fx-font-weight: bold; -fx-font-size: 14;
                                           -fx-background-radius: 9; -fx-padding: 16 0;
                                           -fx-cursor: hand;"/>
                        </VBox>

                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
