                                    <HBox style="-fx-padding: 8 0 0 0;">
                                        <Label text="👑 Owner"
                                               style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size:11;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="showStatOwner" text="—"
                                               style="-fx-text-fill: #ff4d3d; -fx-font-size:12; -fx-font-weight:bold;"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </HBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- ═══════════════════════════════════════
                 VIEW 4 : EDIT
            ═══════════════════════════════════════ -->
            <VBox fx:id="viewEdit" visible="false" managed="false"
                  style="-fx-background-color: #080810;">

                <StackPane prefHeight="200" style="-fx-background-color: #080810;">
                    <Region style="-fx-background-color: rgba(8,8,16,0.98);"/>
                    <VBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 30 48 0 48;">
                        <HBox alignment="CENTER_LEFT" spacing="8"
                              style="-fx-background-color: rgba(232,55,42,0.09);
                                     -fx-border-color: rgba(232,55,42,0.28); -fx-border-width:1;
                                     -fx-border-radius:3; -fx-background-radius:3;
                                     -fx-padding: 4 12 4 12; -fx-max-width:190;">
                            <Label text="●" style="-fx-text-fill: #3dff8a; -fx-font-size:8;"/>
                            <Label text="✏ Team Editor"
                                   style="-fx-text-fill: #ff6b2b; -fx-font-size:10; -fx-font-weight:bold;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Edit"
                                   style="-fx-font-family: 'Arial Black'; -fx-font-size:30;
                                          -fx-font-weight:bold; -fx-text-fill:white;"/>
                            <Label fx:id="editHeroName" text=""
                                   style="-fx-font-family: 'Arial Black'; -fx-font-size:30;
                                          -fx-font-weight:bold; -fx-text-fill: #ff6b2b;"/>
                        </HBox>
                        <Label text="Update your squad configuration."
                               style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size:13;"/>
                    </VBox>
                </StackPane>

                <Region style="-fx-background-color: #ff6b2b; -fx-pref-height:1; -fx-max-height:1;"/>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            VBox.vgrow="ALWAYS" styleClass="scroll-pane"
                            style="-fx-background-color: #080810; -fx-background: #080810;
                                   -fx-border-color: transparent;">
                    <content>
                        <VBox alignment="CENTER" spacing="0"
                              style="-fx-padding: 36 0 60 0; -fx-background-color: #080810;">

                            <HBox style="-fx-padding: 0 0 18 0; -fx-max-width:560;">
                                <Button text="← Back to Team" onAction="#cancelEdit"
                                        style="-fx-background-color: transparent;
                                               -fx-text-fill: rgba(255,255,255,0.45);
                                               -fx-font-size:12; -fx-cursor:hand; -fx-padding:0;"/>
                            </HBox>

                            <VBox spacing="22" maxWidth="560"
                                  style="-fx-background-color: rgba(6,5,16,0.88);
                                         -fx-border-color: rgba(255,107,43,0.22);
                                         -fx-border-radius:16; -fx-background-radius:16;
                                         -fx-padding: 38 38 38 38;">

                                <VBox spacing="7" alignment="CENTER">
                                    <StackPane style="-fx-background-color: rgba(255,107,43,0.1);
                                                      -fx-border-color: rgba(255,107,43,0.3);
                                                      -fx-border-radius:14; -fx-background-radius:14;
                                                      -fx-min-width:54; -fx-max-width:54;
                                                      -fx-min-height:54; -fx-max-height:54;">
                                        <Label text="✏️" style="-fx-font-size:24;"/>
                                    </StackPane>
                                    <Label text="Team Configuration"
                                           style="-fx-text-fill: white; -fx-font-size:18; -fx-font-weight:bold;"/>
                                    <Label text="Modify your squad settings"
                                           style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size:12;"/>
                                </VBox>

                                <Label fx:id="editGeneralError" text=""
                                       visible="false" managed="false" wrapText="true"
                                       style="-fx-text-fill: #ff4d3d; -fx-font-size:12;
                                              -fx-background-color: rgba(232,55,42,0.08);
                                              -fx-border-color: rgba(232,55,42,0.2);
                                              -fx-border-radius:6; -fx-background-radius:6;
                                              -fx-padding: 10 14 10 14;"/>

                                <!-- Team Name -->
                                <VBox spacing="7">
                                    <Label text="🛡 Team Name"
                                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size:12; -fx-font-weight:bold;"/>
                                    <TextField fx:id="editNameField" promptText="Team name" styleClass="input-gaming"/>
                                    <Label fx:id="editNameError" text="" visible="false" managed="false"
                                           style="-fx-text-fill: #ff4d3d; -fx-font-size:11;"/>
                                </VBox>

                                <!-- Description -->
                                <VBox spacing="7">
                                    <Label text="📄 Description"
                                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size:12; -fx-font-weight:bold;"/>
                                    <TextArea fx:id="editDescField" promptText="Team description"
                                              prefRowCount="4" wrapText="true" styleClass="input-gaming"/>
                                </VBox>

                                <!-- Max Members -->
                                <VBox spacing="7">
                                    <Label text="👥 Maximum Members"
                                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size:12; -fx-font-weight:bold;"/>
                                    <HBox spacing="0">
                                        <TextField fx:id="editMaxField" promptText="1–50"
                                                   styleClass="input-gaming" HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: rgba(255,255,255,0.03);
                                                          -fx-border-color: rgba(255,255,255,0.1);
                                                          -fx-border-width:1.5 0 1.5 1.5;
                                                          -fx-border-radius: 9 0 0 9;
                                                          -fx-background-radius: 9 0 0 9;
                                                          -fx-text-fill: rgba(255,255,255,0.93);
                                                          -fx-font-size:13; -fx-padding: 12 14 12 14;"/>
                                        <Label text="🎮 Players"
                                               style="-fx-background-color: #e8372a; -fx-text-fill: white;
                                                      -fx-font-size:12; -fx-font-weight:bold;
                                                      -fx-padding: 12 18 12 18;
                                                      -fx-border-radius: 0 9 9 0; -fx-background-radius: 0 9 9 0;"/>
                                    </HBox>
                                    <Label fx:id="editMaxError" text="" visible="false" managed="false"
                                           style="-fx-text-fill: #ff4d3d; -fx-font-size:11;"/>
                                </VBox>

                                <!-- ══ LOGO UPLOAD (EDIT) ══ -->
                                <VBox spacing="7">
                                    <Label text="🖼 Team Logo"
                                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size:12; -fx-font-weight:bold;"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Button fx:id="editLogoBtn"
                                                text="📁 Choose Image"
                                                onAction="#handleChooseLogoEdit"
                                                style="-fx-background-color: rgba(255,107,43,0.08);
                                                       -fx-border-color: rgba(255,107,43,0.25);
                                                       -fx-border-radius:7; -fx-background-radius:7;
                                                       -fx-text-fill: #ff6b2b; -fx-font-size:11;
                                                       -fx-font-weight:bold;
                                                       -fx-padding: 9 16 9 16; -fx-cursor:hand;"/>
                                        <Label fx:id="editLogoLabel"
                                               text="No file chosen"
                                               style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size:11;"/>
                                    </HBox>
                                    <Label text="▸ Leave empty to keep current logo"
                                           style="-fx-text-fill: rgba(255,255,255,0.28); -fx-font-size:11;"/>
                                </VBox>

                                <!-- Active checkbox -->
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <CheckBox fx:id="editActiveCheck"/>
                                    <Label text="Team is active"
                                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size:12;"/>
                                </HBox>

                                <Region style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-pref-height:1; -fx-max-height:1;"/>

                                <HBox spacing="12">
                                    <Button text="Cancel" onAction="#cancelEdit"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                            style="-fx-background-color: rgba(255,255,255,0.05);
                                                   -fx-border-color: rgba(255,255,255,0.1);
                                                   -fx-border-radius:9; -fx-background-radius:9;
                                                   -fx-text-fill: rgba(255,255,255,0.5);
                                                   -fx-font-size:12; -fx-font-weight:bold;
                                                   -fx-padding: 13; -fx-cursor:hand;"/>
                                    <Button fx:id="editSubmitBtn" text="💾  Save Changes"
                                            onAction="#handleEditSubmit"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                            styleClass="btn-fire"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
