<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eyetwin.controller.HomeController"
            stylesheets="@../styles/gaming.css"
            style="-fx-background-color: #080810;"
            prefWidth="1280" prefHeight="800">

    <!-- ══════════════════════════════════════════════════
         NAVBAR — mirror of Symfony .main_menu
    ══════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: rgba(8,8,16,0.95);
                     -fx-border-color: rgba(232,55,42,0.15);
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 24 0 24;
                     -fx-pref-height: 64;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.6),20,0,0,4);">

            <!-- Logo -->
            <ImageView fitHeight="40" preserveRatio="true" pickOnBounds="true"
                       onMouseClicked="#goHome" style="-fx-cursor: hand;">
                <image><Image url="@../assets/img/eyetwin-logo.png"/></image>
            </ImageView>

            <Region style="-fx-min-width: 22;"/>

            <!-- ── Nav links (always visible) ── -->
            <Label text="HOME" onMouseClicked="#goHome"
                   style="-fx-text-fill: white; -fx-font-size:10; -fx-font-weight:bold;
                          -fx-font-family:'Arial'; -fx-letter-spacing:1;
                          -fx-padding: 22 14 22 14; -fx-cursor: hand;
                          -fx-border-color: transparent transparent #e8372a transparent;
                          -fx-border-width: 0 0 2 0;"/>
            <Label text="PLANNING" onMouseClicked="#goToPlanning"
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10; -fx-font-weight:bold;
                          -fx-padding: 22 14 22 14; -fx-cursor: hand;"/>
            <Label text="TOURNOIS"
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10; -fx-font-weight:bold;
                          -fx-padding: 22 14 22 14; -fx-cursor: hand;"/>

            <!-- ── HIGHLIGHTS — direct link (logged in only) ── -->
            <Label fx:id="navHighlights" text="HIGHLIGHTS"
                   visible="false" managed="false"
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10; -fx-font-weight:bold;
                          -fx-padding: 22 14 22 14; -fx-cursor: hand;"/>

            <!-- ── UPLOADER dropdown (logged in only) — MenuButton simulates Bootstrap dropdown ── -->
            <MenuButton fx:id="navUploaderMenu"
                        visible="false" managed="false"
                        text="⬆  UPLOADER"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: rgba(255,255,255,0.5);
                               -fx-font-size:10; -fx-font-weight:bold;
                               -fx-padding: 22 14 22 10;
                               -fx-border-color: transparent;
                               -fx-mark-color: rgba(255,255,255,0.3);
                               -fx-cursor: hand;">
                <!-- animated red dot prefix is visual-only via Label trick below -->
                <items>
                    <MenuItem fx:id="menuUpload"    text="⬆  Uploader"  onAction="#goToVideos"/>
                    <MenuItem fx:id="menuMyClips"   text="🎬  My Clips"  onAction="#goToClips"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuGuides"    text="📖  Guides"    onAction="#goToGuides"/>
                </items>
            </MenuButton>

            <Label text="TEAMS" onMouseClicked="#goToTeams"
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10; -fx-font-weight:bold;
                          -fx-padding: 22 14 22 14; -fx-cursor: hand;"/>
            <Label text="COMMUNITY"
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10; -fx-font-weight:bold;
                          -fx-padding: 22 14 22 14; -fx-cursor: hand;"/>

            <!-- ── LIVE with red dot ── -->
            <HBox alignment="CENTER" spacing="5"
                  style="-fx-padding: 22 14 22 14; -fx-cursor: hand;">
                <Label text="●"
                       style="-fx-text-fill: #ff4d3d; -fx-font-size: 7;
                              -fx-effect: dropshadow(gaussian,#ff4d3d,8,0,0,0);"/>
                <Label text="LIVE"
                       style="-fx-text-fill: #ff4d3d; -fx-font-size:10; -fx-font-weight:bold;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- ══════════════════════════════════════
                 RIGHT SIDE — logged IN zone
            ══════════════════════════════════════ -->
            <HBox fx:id="loggedInZone" alignment="CENTER" spacing="8"
                  visible="false" managed="false">

                <!-- Coins pill — like .nav-coins-pill -->
                <HBox fx:id="coinsBadge" alignment="CENTER" spacing="6"
                      onMouseClicked="#goToCoins"
                      style="-fx-background-color: linear-gradient(90deg,#f6d860,#f6ad55);
                             -fx-background-radius: 20; -fx-padding: 5 13 5 13;
                             -fx-cursor: hand;
                             -fx-effect: dropshadow(gaussian,rgba(246,216,96,0.3),10,0,0,0);">
                    <Label text="🪙" style="-fx-font-size: 11;"/>
                    <Label fx:id="coinsNavLabel" text="0"
                           style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #1a1a2e;"/>
                </HBox>

                <!-- ── Bell / Notifications dropdown — like .nav-bell ── -->
                <MenuButton fx:id="navNotifMenu"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: transparent;
                                   -fx-text-fill: rgba(255,255,255,0.65);
                                   -fx-font-size: 14;
                                   -fx-mark-color: transparent;
                                   -fx-padding: 6 8 6 8;
                                   -fx-cursor: hand;">
                    <!-- Bell icon set in controller via setText or graphic -->
                    <graphic>
                        <StackPane>
                            <Label text="🔔" style="-fx-font-size:16;"/>
                            <!-- unread badge -->
                            <Label fx:id="navNotifBadge" text=""
                                   visible="false" managed="false"
                                   style="-fx-background-color: #e8372a;
                                          -fx-text-fill: white;
                                          -fx-font-size: 8; -fx-font-weight:bold;
                                          -fx-background-radius: 10;
                                          -fx-padding: 1 4 1 4;
                                          -fx-translate-x: 8; -fx-translate-y: -8;
                                          -fx-effect: dropshadow(gaussian,rgba(232,55,42,0.5),6,0,0,0);"/>
                        </StackPane>
                    </graphic>
                    <items>
                        <!-- Header item (non-clickable style) -->
                        <MenuItem fx:id="notifHeaderItem" text="🔔  Notifications"
                                  style="-fx-font-weight:bold; -fx-text-fill:#ff4d3d;" disable="true"/>
                        <SeparatorMenuItem/>
                        <!-- Dynamic notifications injected by controller via getItems() -->
                        <MenuItem fx:id="notifEmptyItem" text="✅  All caught up"
                                  disable="true"
                                  style="-fx-text-fill: rgba(255,255,255,0.35);"/>
                    </items>
                </MenuButton>

                <!-- ── Profile dropdown — like .et-profile-trigger + .et-profile-menu ── -->
                <MenuButton fx:id="navProfileMenu"
                            style="-fx-background-color: rgba(255,255,255,0.03);
                                   -fx-border-color: rgba(232,55,42,0.18);
                                   -fx-border-radius: 50; -fx-background-radius: 50;
                                   -fx-padding: 4 12 4 4;
                                   -fx-mark-color: rgba(255,255,255,0.3);
                                   -fx-cursor: hand;">
                    <graphic>
                        <HBox alignment="CENTER" spacing="7">
                            <!-- Avatar circle with initial -->
                            <StackPane style="-fx-background-color: linear-gradient(135deg,#b02b20,#ff4d3d);
                                              -fx-background-radius: 50;
                                              -fx-min-width: 28; -fx-min-height: 28;
                                              -fx-max-width: 28; -fx-max-height: 28;">
                                <Label fx:id="navAvatarInitial" text="A"
                                       style="-fx-text-fill: white; -fx-font-weight:900; -fx-font-size:12;"/>
                            </StackPane>
                            <!-- Username -->
                            <Label fx:id="navUsername" text="PLAYER"
                                   style="-fx-text-fill: white; -fx-font-weight:bold; -fx-font-size:10;"/>
                            <!-- Online dot -->
                            <Label text="●"
                                   style="-fx-text-fill: #00e676; -fx-font-size: 7;
                                          -fx-effect: dropshadow(gaussian,#00e676,6,0,0,0);"/>
                        </HBox>
                    </graphic>
                    <items>
                        <!-- ── Header (disabled display item) ── -->
                        <MenuItem fx:id="profileHeaderItem" text=""
                                  disable="true"
                                  style="-fx-font-family:'Arial'; -fx-font-size:11;
                                         -fx-text-fill:rgba(255,255,255,0.35);"/>

                        <!-- ── Stats row ── -->
                        <MenuItem fx:id="profileStatsItem" text=""
                                  disable="true"
                                  style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size:10;"/>

                        <SeparatorMenuItem/>

                        <!-- My Profile -->
                        <MenuItem text="👤  My Profile"
                                  onAction="#goToProfile"
                                  style="-fx-font-size:11;"/>

                        <!-- Two-Factor Auth -->
                        <MenuItem text="🛡  Two-Factor Auth"
                                  onAction="#goTo2FA"
                                  style="-fx-font-size:11;"/>

                        <!-- Support -->
                        <MenuItem text="🎧  Support"
                                  onAction="#goToSupport"
                                  style="-fx-font-size:11;"/>

                        <SeparatorMenuItem/>

                        <!-- Admin (shown/hidden by controller based on role) -->
                        <MenuItem fx:id="profileAdminItem"
                                  text="⚙  Administration"
                                  visible="false"
                                  onAction="#goToAdmin"
                                  style="-fx-font-size:11; -fx-text-fill:#f6d860;"/>

                        <SeparatorMenuItem fx:id="profileAdminSep" visible="false"/>

                        <!-- Logout -->
                        <MenuItem text="🚪  Logout"
                                  onAction="#handleLogout"
                                  style="-fx-font-size:11; -fx-text-fill:#ff4d3d;"/>
                    </items>
                </MenuButton>

            </HBox>

            <!-- ══════════════════════════════════════
                 RIGHT SIDE — GUEST zone
            ══════════════════════════════════════ -->
            <HBox fx:id="guestZone" alignment="CENTER" spacing="10"
                  visible="true" managed="true">
                <Button text="SIGN IN" onAction="#goToLogin"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: rgba(255,255,255,0.5);
                               -fx-font-size:10; -fx-font-weight:bold;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.15);
                               -fx-border-radius: 20; -fx-background-radius: 20;
                               -fx-padding: 8 16 8 16;"/>
                <Button text="GET STARTED" onAction="#goToRegister"
                        style="-fx-background-color: linear-gradient(135deg,#b02b20,#e8372a,#ff4d3d);
                               -fx-text-fill: white; -fx-font-weight:bold; -fx-font-size:10;
                               -fx-cursor: hand; -fx-background-radius: 20;
                               -fx-padding: 8 16 8 16;
                               -fx-effect: dropshadow(gaussian,rgba(232,55,42,0.4),10,0,0,0);"/>
            </HBox>

        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════
         MAIN SCROLL (unchanged)
    ══════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="scroll-pane"
                    style="-fx-background-color: #080810; -fx-background: #080810;
                           -fx-border-color: transparent;">
            <VBox style="-fx-background-color: #080810;">

                <!-- ══════════════════════════════════
                     HERO SECTION
                ══════════════════════════════════ -->
                <StackPane prefHeight="620"
                           style="-fx-background-color: #05040f;">
                    <ImageView fx:id="heroImage" fitWidth="1280" fitHeight="620"
                               preserveRatio="false" smooth="true" opacity="0.22">
                        <image><Image url="@../assets/img/latest_war_img_1.png"/></image>
                    </ImageView>
                    <Region style="-fx-background-color:
                        linear-gradient(to bottom,
                            rgba(5,4,15,0.25) 0%,
                            rgba(5,4,15,0.65) 50%,
                            rgba(5,4,15,0.97) 100%);"/>
                    <Region style="-fx-background-color:
                        radial-gradient(center 50% 50%, radius 70%, transparent 25%, rgba(0,0,0,0.8) 100%);"/>

                    <VBox alignment="CENTER_LEFT" spacing="0"
                          style="-fx-padding: 0 80 60 80;">
                        <HBox alignment="CENTER_LEFT" spacing="8"
                              style="-fx-background-color: rgba(232,55,42,0.08);
                                     -fx-border-color: rgba(232,55,42,0.25);
                                     -fx-border-width:1; -fx-background-radius:3; -fx-border-radius:3;
                                     -fx-padding: 5 14 5 14; -fx-max-width: 270;">
                            <Label text="●"
                                   style="-fx-text-fill: #00e676; -fx-font-size:8;
                                          -fx-effect: dropshadow(gaussian,#00e676,8,0,0,0);"/>
                            <Label text="EYETWIN ESPORT PLATFORM"
                                   style="-fx-text-fill: #ff4d3d; -fx-font-size:10; -fx-font-weight:bold;"/>
                        </HBox>
                        <Region style="-fx-pref-height: 22;"/>
                        <Label text="Dominate"
                               style="-fx-font-family: 'Arial Black';
                                      -fx-font-size: 78; -fx-font-weight: bold;
                                      -fx-text-fill: white;
                                      -fx-effect: dropshadow(gaussian,rgba(255,255,255,0.1),20,0,0,0);"/>
                        <Label text="The Arena"
                               style="-fx-font-family: 'Arial Black';
                                      -fx-font-size: 78; -fx-font-weight: bold;
                                      -fx-text-fill: #e8372a;
                                      -fx-effect: dropshadow(gaussian,rgba(232,55,42,0.65),40,0,0,0);"/>
                        <Region style="-fx-pref-height: 18;"/>
                        <Label text="Intelligent analysis · Personalized coaching · Competitive tournaments."
                               style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 14;"/>
                        <Label text="Level up your game with the ultimate eSport ecosystem."
                               style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 14;"/>
                        <Region style="-fx-pref-height: 30;"/>

                        <!-- CTA GUEST -->
                        <HBox fx:id="heroCTAGuest" spacing="14" alignment="CENTER_LEFT"
                              visible="true" managed="true">
                            <Button text="⚡  Get Started" onAction="#goToRegister"
                                    style="-fx-background-color: linear-gradient(135deg,#b02b20,#e8372a,#ff4d3d);
                                           -fx-text-fill: white; -fx-font-weight:bold; -fx-font-size:13;
                                           -fx-background-radius:9; -fx-padding: 14 28 14 28;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian,rgba(232,55,42,0.55),22,0,0,5);"/>
                            <Button text="→  Sign In" onAction="#goToLogin"
                                    style="-fx-background-color: rgba(255,255,255,0.04);
                                           -fx-text-fill: rgba(255,255,255,0.6); -fx-font-weight:bold;
                                           -fx-font-size:13; -fx-background-radius:9;
                                           -fx-border-color: rgba(255,255,255,0.12);
                                           -fx-border-width:1; -fx-border-radius:9;
                                           -fx-padding: 14 28 14 28; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- CTA LOGGED IN -->
                        <HBox fx:id="heroCTAUser" spacing="14" alignment="CENTER_LEFT"
                              visible="false" managed="false">
                            <Button text="⬆  Upload a Video" onAction="#goToVideos"
                                    style="-fx-background-color: linear-gradient(135deg,#b02b20,#e8372a,#ff4d3d);
                                           -fx-text-fill: white; -fx-font-weight:bold; -fx-font-size:13;
                                           -fx-background-radius:9; -fx-padding: 14 28 14 28;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian,rgba(232,55,42,0.55),22,0,0,5);"/>
                            <Button text="● Watch Live"
                                    style="-fx-background-color: rgba(255,255,255,0.04);
                                           -fx-text-fill: rgba(255,255,255,0.6); -fx-font-weight:bold;
                                           -fx-font-size:13; -fx-background-radius:9;
                                           -fx-border-color: rgba(255,255,255,0.12);
                                           -fx-border-width:1; -fx-border-radius:9;
                                           -fx-padding: 14 28 14 28; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- ══════════════════════════════════
                     STATS BAR
                ══════════════════════════════════ -->
                <HBox alignment="CENTER"
                      style="-fx-background-color: rgba(0,0,0,0.5);
                             -fx-border-color: rgba(232,55,42,0.1) transparent;
                             -fx-border-width: 1 0;
                             -fx-padding: 18 0 18 0;">
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statPlayers" text="0" styleClass="stat-val"/>
                        <Label text="PLAYERS" styleClass="stat-lbl"/>
                    </VBox>
                    <Region style="-fx-background-color: rgba(232,55,42,0.25);
                                   -fx-pref-width:1; -fx-pref-height:40; -fx-max-height:40;"/>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statTournaments" text="0" styleClass="stat-val"/>
                        <Label text="TOURNAMENTS" styleClass="stat-lbl"/>
                    </VBox>
                    <Region style="-fx-background-color: rgba(232,55,42,0.25);
                                   -fx-pref-width:1; -fx-pref-height:40; -fx-max-height:40;"/>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statTeams" text="0" styleClass="stat-val"/>
                        <Label text="TEAMS" styleClass="stat-lbl"/>
                    </VBox>
                    <Region style="-fx-background-color: rgba(232,55,42,0.25);
                                   -fx-pref-width:1; -fx-pref-height:40; -fx-max-height:40;"/>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="statCoaches" text="0" styleClass="stat-val"/>
                        <Label text="COACHES" styleClass="stat-lbl"/>
                    </VBox>
                </HBox>

                <!-- ══════════════════════════════════
                     FEATURES SECTION
                ══════════════════════════════════ -->
                <VBox style="-fx-background-color: #080810; -fx-padding: 64 64 64 64;">
                    <VBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 44 0;">
                        <Label text="Platform Features" styleClass="section-tag"/>
                        <Label text="Everything You Need To Win" styleClass="section-title"/>
                        <Label text="A complete ecosystem built for competitive players and coaches."
                               styleClass="section-sub"/>
                    </VBox>
                    <HBox spacing="18" style="-fx-padding: 0 0 18 0;">
                        <VBox spacing="12" HBox.hgrow="ALWAYS" onMouseClicked="#goToVideos"
                              styleClass="feat-card-highlight">
                            <StackPane style="-fx-background-color: rgba(232,55,42,0.1);
                                              -fx-border-color: rgba(232,55,42,0.25);
                                              -fx-border-radius:12; -fx-background-radius:12;
                                              -fx-min-width:52; -fx-max-width:52;
                                              -fx-min-height:52; -fx-max-height:52;">
                                <Label text="▶" style="-fx-font-size:22; -fx-text-fill:#ff4d3d;"/>
                            </StackPane>
                            <Label text="Video Analysis" styleClass="feat-title"/>
                            <Label text="Upload your match recordings and get AI-powered breakdowns of your gameplay, positioning, and decision-making."
                                   styleClass="feat-desc"/>
                            <Label text="Upload Now →" styleClass="feat-link"/>
                        </VBox>
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="feat-card">
                            <StackPane style="-fx-background-color: rgba(232,55,42,0.1);
                                              -fx-border-color: rgba(232,55,42,0.25);
                                              -fx-border-radius:12; -fx-background-radius:12;
                                              -fx-min-width:52; -fx-max-width:52;
                                              -fx-min-height:52; -fx-max-height:52;">
                                <Label text="📡" style="-fx-font-size:22;"/>
                            </StackPane>
                            <Label text="Live Streams" styleClass="feat-title"/>
                            <Label text="Watch expert coaches stream in real time. Ask questions, learn techniques, and level up live."
                                   styleClass="feat-desc"/>
                            <Label text="Watch Live →" styleClass="feat-link"/>
                        </VBox>
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="feat-card">
                            <StackPane style="-fx-background-color: rgba(232,55,42,0.1);
                                              -fx-border-color: rgba(232,55,42,0.25);
                                              -fx-border-radius:12; -fx-background-radius:12;
                                              -fx-min-width:52; -fx-max-width:52;
                                              -fx-min-height:52; -fx-max-height:52;">
                                <Label text="🏆" style="-fx-font-size:22;"/>
                            </StackPane>
                            <Label text="Tournaments" styleClass="feat-title"/>
                            <Label text="Compete in structured brackets, climb the leaderboard, and prove your skills against top players."
                                   styleClass="feat-desc"/>
                            <Label text="Browse Tournois →" styleClass="feat-link"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="18">
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="feat-card">
                            <StackPane style="-fx-background-color: rgba(232,55,42,0.1);
                                              -fx-border-color: rgba(232,55,42,0.25);
                                              -fx-border-radius:12; -fx-background-radius:12;
                                              -fx-min-width:52; -fx-max-width:52;
                                              -fx-min-height:52; -fx-max-height:52;">
                                <Label text="📅" style="-fx-font-size:22;"/>
                            </StackPane>
                            <Label text="Training Sessions" styleClass="feat-title"/>
                            <Label text="Book structured coaching sessions, track your progress, and join group training with elite coaches."
                                   styleClass="feat-desc"/>
                            <Label text="View Planning →" styleClass="feat-link" onMouseClicked="#goToPlanning"/>
                        </VBox>
                        <VBox spacing="12" HBox.hgrow="ALWAYS" onMouseClicked="#goToTeams" styleClass="feat-card">
                            <StackPane style="-fx-background-color: rgba(232,55,42,0.1);
                                              -fx-border-color: rgba(232,55,42,0.25);
                                              -fx-border-radius:12; -fx-background-radius:12;
                                              -fx-min-width:52; -fx-max-width:52;
                                              -fx-min-height:52; -fx-max-height:52;">
                                <Label text="👥" style="-fx-font-size:22;"/>
                            </StackPane>
                            <Label text="Teams" styleClass="feat-title"/>
                            <Label text="Form or join a team, coordinate strategies, and compete together in organized team events."
                                   styleClass="feat-desc"/>
                            <Label text="My Teams →" styleClass="feat-link"/>
                        </VBox>
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="feat-card">
                            <StackPane style="-fx-background-color: rgba(232,55,42,0.1);
                                              -fx-border-color: rgba(232,55,42,0.25);
                                              -fx-border-radius:12; -fx-background-radius:12;
                                              -fx-min-width:52; -fx-max-width:52;
                                              -fx-min-height:52; -fx-max-height:52;">
                                <Label text="💬" style="-fx-font-size:22;"/>
                            </StackPane>
                            <Label text="Community" styleClass="feat-title"/>
                            <Label text="Connect with players across all games, share clips, strategies, and build your network."
                                   styleClass="feat-desc"/>
                            <Label text="Join Community →" styleClass="feat-link"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ══════════════════════════════════
                     EVENT SECTION
                ══════════════════════════════════ -->
                <StackPane prefHeight="380" style="-fx-background-color: #05040f;">
                    <ImageView fitWidth="1280" fitHeight="380"
                               preserveRatio="false" smooth="true" opacity="0.3">
                        <image><Image url="@../assets/img/latest_war_img_1.png"/></image>
